{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-set-badge-count",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" },
        { "path": "$TEMP/**" },
        { "path": "/Applications/**" }
      ]
    },
    "opener:allow-open-url",
    "opener:allow-reveal-item-in-dir",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "notification:allow-is-permission-granted",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "$RESOURCE/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "$TEMP/**" },
        { "path": "/Applications" },
        { "path": "/Applications/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "$RESOURCE/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "$TEMP/**" },
        { "path": "/Applications" },
        { "path": "/Applications/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/.abu/**/.trash" },
        { "path": "$HOME/.abu/**/.trash/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "$RESOURCE/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "/Volumes/**/.abu/**/.trash" },
        { "path": "/Volumes/**/.abu/**/.trash/**" },
        { "path": "$TEMP/**" },
        { "path": "/Applications" },
        { "path": "/Applications/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "$RESOURCE/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" },
        { "path": "/Volumes/**/.abu" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "$TEMP/**" },
        { "path": "/Applications" },
        { "path": "/Applications/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/.abu/**/.trash" },
        { "path": "$HOME/.abu/**/.trash/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "/Volumes/**/.abu" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "/Volumes/**/.abu/**/.trash" },
        { "path": "/Volumes/**/.abu/**/.trash/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/.abu/**/.trash/**" },
        { "path": "$HOME/**/.abu/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "$RESOURCE/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "$TEMP/**" },
        { "path": "/Applications" },
        { "path": "/Applications/**" }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/.abu/**/.trash/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" },
        { "path": "/Volumes/**/.abu/**" },
        { "path": "/Volumes/**/.abu/**/.trash/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "https://*:*" },
        { "url": "http://*:*" }
      ]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/.abu/**" },
        { "path": "$HOME/**/.abu" },
        { "path": "$HOME/**/.abu/**" },
        { "path": "/tmp/**" },
        { "path": "/private/tmp/**" },
        { "path": "/Volumes/**" },
        { "path": "$TEMP/**" }
      ]
    },
    "fs:allow-unwatch",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered",
    "updater:default",
    "process:default",
    "deep-link:default"
  ]
}
